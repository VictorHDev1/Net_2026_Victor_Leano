@model Net_2026_Victor_Leano.Models.LoginRequest
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta name="viewport" content="width=device-width" />

    <title>Login</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg,#1e3c72,#2a5298);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-card {
            width: 420px;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            background: white;
        }

        .login-title {
            text-align: center;
            font-weight: 600;
            margin-bottom: 30px;
        }

        .btn-login {
            width: 100%;
            padding: 10px;
            font-weight: 600;
        }

        .logo {
            text-align: center;
            margin-bottom: 20px;
            font-size: 28px;
            font-weight: 700;
            color: #2a5298;
        }
    </style>

</head>

<body>

    <div class="login-card">

        <div class="logo">
            Secure Login
        </div>

        <h4 class="login-title">Sign in to your account</h4>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">
                @ViewBag.Error
            </div>
        }

        <form method="post">

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input asp-for="userName" class="form-control" placeholder="Enter your username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="password" type="password" class="form-control" placeholder="Enter your password" />
            </div>

            <button type="submit" class="btn btn-primary btn-login">
                Login
            </button>

        </form>

    </div>

</body>
</html>